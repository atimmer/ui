{
  "name": "@24letters/ui",
  "version": "0.1.0",
  "description": "The complete shadcn component catalog in the compact 24letters Base Mira theme.",
  "homepage": "https://github.com/atimmer/ui#readme",
  "bugs": {
    "url": "https://github.com/atimmer/ui/issues"
  },
  "license": "MIT",
  "author": "Anton Timmer",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/atimmer/ui.git"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./styles.css": {
      "style": "./src/styles.css",
      "default": "./src/styles.css"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test --passWithNoTests",
    "check": "vp check",
    "prepublishOnly": "vp run build"
  },
  "dependencies": {
    "@base-ui/react": "catalog:",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/newsreader": "^5.2.10",
    "@phosphor-icons/react": "^2.1.10",
    "@shadcn/react": "catalog:",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "catalog:",
    "date-fns": "catalog:",
    "embla-carousel-react": "catalog:",
    "input-otp": "catalog:",
    "next-themes": "catalog:",
    "react-day-picker": "catalog:",
    "react-resizable-panels": "catalog:",
    "recharts": "catalog:",
    "shadcn": "^4.13.0",
    "sonner": "catalog:",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "~6.0.2",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  }
}
